<%- include('../partials/header') %>
<h2>Search Posts</h2>
<p><a href="/courses/<%= course_id %>/posts">Back to posts</a></p>
<form method="get" action="/courses/<%= course_id %>/search">
  <input name="keyword" value="<%= keyword %>" placeholder="keyword" />
  <button type="submit">Search</button>
</form>
<% posts.forEach(p => { %>
  <div class="card">
    <h3><a href="/courses/<%= course_id %>/posts/<%= p.post_id %>"><%= p.title %></a></h3>
    <p class="muted">by <%= p.author_username %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
