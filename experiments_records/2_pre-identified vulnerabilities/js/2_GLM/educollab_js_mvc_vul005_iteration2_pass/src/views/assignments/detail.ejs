<%- include('../partials/header') %>
<p><a href="/courses/<%= course_id %>/assignments">Back</a></p>
<h2><%= assignment.title %></h2>
<div class="card">
  <p><%= assignment.description %></p>
  <p class="muted">Due: <%= assignment.due_at %></p>
  <p>
    <a href="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>/edit">Edit</a>
    | <a href="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>/submit">Submit (student)</a>
    | <a href="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>/submissions">View submissions (staff)</a>
  </p>
  <form method="post" action="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>/delete" onsubmit="return confirm('Delete assignment?')">
    <button type="submit">Delete</button>
  </form>
</div>
<%- include('../partials/footer') %>
