<%- include('../partials/header') %>
<h2>My Submissions</h2>
<% submissions.forEach(s => { %>
  <div class="card">
    <h3><%= s.course_title %> / <%= s.assignment_title %></h3>
    <p class="muted">Updated: <%= s.updated_at %></p>
    <p><%= s.content_text.slice(0,200) %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
