<%- include('../partials/header') %>
<p><a href="/courses/<%= course_id %>/posts">Back</a></p>
<h2><%= post.title %></h2>
<p class="muted">by <%= post.author_username %> • <%= post.created_at %></p>
<div class="card">
  <p><%= post.body %></p>
  <p><a href="/courses/<%= course_id %>/posts/<%= post.post_id %>/edit">Edit</a></p>
  <form method="post" action="/courses/<%= course_id %>/posts/<%= post.post_id %>/delete" onsubmit="return confirm('Delete post?')">
    <button type="submit">Delete</button>
  </form>
</div>

<h3>Comments</h3>
<div class="card">
  <% comments.forEach(c => { %>
    <div style="border-bottom:1px solid #eee;padding:8px 0">
      <p class="muted"><%= c.author_username %> • <%= c.created_at %></p>
      <form method="post" action="/courses/<%= course_id %>/posts/<%= post.post_id %>/comments/<%= c.comment_id %>">
        <textarea name="body" rows="2"><%= c.body %></textarea>
        <button type="submit">Update</button>
      </form>
      <form method="post" action="/courses/<%= course_id %>/posts/<%= post.post_id %>/comments/<%= c.comment_id %>/delete" onsubmit="return confirm('Delete comment?')">
        <button type="submit">Delete</button>
      </form>
    </div>
  <% }) %>

  <h4>Add comment</h4>
  <form method="post" action="/courses/<%= course_id %>/posts/<%= post.post_id %>/comments">
    <textarea name="body" rows="3"></textarea>
    <button type="submit">Add</button>
  </form>
</div>
<%- include('../partials/footer') %>
