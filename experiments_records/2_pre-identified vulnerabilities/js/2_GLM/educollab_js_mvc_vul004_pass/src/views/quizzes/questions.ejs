<%- include('../partials/header') %>
<h2>Configure Quiz Questions: <%= quiz.title %></h2>
<p><a href="/courses/<%= course_id %>/quizzes/<%= quiz_id %>">Back</a></p>
<div class="card">
  <h3>Add question to quiz</h3>
  <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz_id %>/questions">
    <label>Question</label>
    <select name="question_id">
      <% questions.forEach(q => { %>
        <option value="<%= q.question_id %>">Q<%= q.question_id %>: <%= q.prompt.slice(0,60) %></option>
      <% }) %>
    </select>
    <div class="row">
      <div>
        <label>points</label>
        <input name="points" value="1" />
      </div>
      <div>
        <label>position</label>
        <input name="position" value="1" />
      </div>
    </div>
    <button type="submit">Add/Update</button>
  </form>
</div>

<h3>Current quiz questions</h3>
<div class="card">
  <% quizQuestions.forEach(qq => { %>
    <div style="border-bottom:1px solid #eee;padding:8px 0">
      <p>#<%= qq.position %> — Q<%= qq.question_id %> — <%= qq.points %> pts</p>
      <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz_id %>/questions/<%= qq.question_id %>/delete" onsubmit="return confirm('Remove question?')">
        <button type="submit">Remove</button>
      </form>
    </div>
  <% }) %>
</div>
<%- include('../partials/footer') %>
