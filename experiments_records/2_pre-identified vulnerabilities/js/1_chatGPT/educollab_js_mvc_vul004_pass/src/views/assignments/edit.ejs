<%- include('../partials/header') %>
<h2>Edit Assignment</h2>
<p><a href="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/assignments/<%= assignment.assignment_id %>">
  <label>Title</label>
  <input name="title" value="<%= assignment.title %>" />
  <label>Description</label>
  <textarea name="description" rows="6"><%= assignment.description %></textarea>
  <label>Due at</label>
  <input name="due_at" value="<%= assignment.due_at %>" />
  <button type="submit">Save</button>
</form>
<%- include('../partials/footer') %>
