<%- include('../partials/header') %>
<h2>Submit Assignment</h2>
<p><a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>">Back</a></p>
<div class="card">
  <p class="muted">You can optionally attach an existing upload_id (created by staff).</p>
  <form method="post" action="/courses/<%= course_id %>/assignments/<%= assignment_id %>/submissions">
    <label>Content</label>
    <textarea name="content_text" rows="6"><%= existing ? existing.content_text : '' %></textarea>
    <label>attachment_upload_id (optional)</label>
    <input name="attachment_upload_id" value="<%= existing && existing.attachment_upload_id ? existing.attachment_upload_id : '' %>" />
    <button type="submit"><%= existing ? 'Update' : 'Submit' %></button>
  </form>
</div>
<%- include('../partials/footer') %>
