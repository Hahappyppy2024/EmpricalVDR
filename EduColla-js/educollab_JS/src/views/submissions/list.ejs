<%- include('../partials/header') %>
<h2>Submissions for Assignment <%= assignment_id %></h2>
<p><a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>/grades/export.csv">Export Grades CSV</a></p>
<p><a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>">Back</a></p>
<p>
  <a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>/grades/export.csv">Export Grades CSV</a> |
  <a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>/grades/import">Import Grades CSV</a>
</p>
<form method="post" action="/courses/<%= course_id %>/assignments/<%= assignment_id %>/submissions/export" style="margin-bottom:10px;">
  <button type="submit">Export All Submissions ZIP</button>
</form>
<div class="card">
  <table width="100%" border="1" cellspacing="0" cellpadding="6">
    <tr><th>submission_id</th><th>student</th><th>updated_at</th><th>content</th><th>attachment</th><th>actions</th></tr>
    <% submissions.forEach(s => { %>
      <tr>
        <td><%= s.submission_id %></td>
        <td><%= s.student_username %> (id=<%= s.student_id %>)</td>
        <td><%= s.updated_at %></td>
        <td><%= s.content_text.slice(0,120) %></td>
        <td><%= s.attachment_upload_id || '' %></td>
      </tr>
    <% }) %>
  </table>
</div>
<%- include('../partials/footer') %>
