<%- include('../partials/header') %>
<h2>Add Member</h2>
<p><a href="/courses/<%= course_id %>/members">Back</a></p>
<% if (typeof error !== 'undefined' && error) { %><p style="color:red"><%= error %></p><% } %>
<form method="post" action="/courses/<%= course_id %>/members">
  <label>User</label>
  <select name="user_id">
    <% users.forEach(u => { %>
      <option value="<%= u.user_id %>"><%= u.username %> (<%= u.display_name %>)</option>
    <% }) %>
  </select>
  <label>Role</label>
  <select name="role_in_course">
    <% roles.forEach(r => { %>
      <option value="<%= r %>"><%= r %></option>
    <% }) %>
  </select>
  <button type="submit">Add</button>
</form>
<%- include('../partials/footer') %>
