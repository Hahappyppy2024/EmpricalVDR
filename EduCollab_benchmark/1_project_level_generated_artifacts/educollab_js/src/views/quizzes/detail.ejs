<%- include('../partials/header') %>
<p><a href="/courses/<%= course_id %>/quizzes">Back</a></p>
<h2><%= quiz.title %></h2>
<div class="card">
  <p><%= quiz.description %></p>
  <p class="muted">Open: <%= quiz.open_at %> • Due: <%= quiz.due_at %></p>
  <p>
    <a href="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>/edit">Edit</a>
    | <a href="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>/questions">Configure questions (staff)</a>
  </p>
  <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>/delete" onsubmit="return confirm('Delete quiz?')">
    <button type="submit">Delete</button>
  </form>
</div>

<h3>Quiz Questions</h3>
<div class="card">
  <% if (quizQuestions.length === 0) { %>
    <p class="muted">No questions configured yet.</p>
  <% } %>
  <% quizQuestions.forEach(qq => { %>
    <p>#<%= qq.position %> Q<%= qq.question_id %> (<%= qq.qtype %>) — <%= qq.points %> pts</p>
  <% }) %>

  <h3>Student</h3>
  <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>/start">
    <button type="submit">Start attempt (student)</button>
  </form>
</div>
<%- include('../partials/footer') %>
