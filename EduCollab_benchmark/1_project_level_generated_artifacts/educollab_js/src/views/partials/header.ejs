<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>EduCollab JS MVC v0</title>
  <style>
    body{font-family:system-ui,Segoe UI,Arial,sans-serif;max-width:980px;margin:20px auto;padding:0 12px;}
    nav a{margin-right:10px;}
    .card{border:1px solid #ddd;border-radius:8px;padding:12px;margin:12px 0;}
    input,textarea,select{width:100%;padding:8px;margin:6px 0;}
    button{padding:8px 12px;}
    .row{display:flex;gap:10px;}
    .row > *{flex:1;}
    .muted{color:#666;}
  </style>
</head>
<body>
<nav>
  <a href="/">Home</a>
  <% if (me) { %>
    <a href="/me">Me</a>
    <a href="/courses">Courses</a>
    <a href="/memberships">My Memberships</a>
    <a href="/my/submissions">My Submissions</a>
    <a href="/my/quizzes">My Quiz Attempts</a>
    <% if (me.username === 'admin') { %><a href="/admin/users">Admin: Users</a><% } %>
    <form action="/logout" method="post" style="display:inline">
      <button type="submit">Logout</button>
    </form>
  <% } else { %>
    <a href="/login">Login</a>
    <a href="/register">Register</a>
  <% } %>
</nav>
<hr/>
