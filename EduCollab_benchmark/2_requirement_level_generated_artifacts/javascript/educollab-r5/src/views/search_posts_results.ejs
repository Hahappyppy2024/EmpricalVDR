<%- include('partials/header') %>
<h1>Search Posts: <%= course.title %></h1>
<form method="get" action="/courses/<%= course.course_id %>/search">
  <input type="text" name="keyword" value="<%= keyword %>">
  <button type="submit">Search</button>
</form>
<ul>
  <% posts.forEach(function(post) { %>
    <li><a href="/courses/<%= course.course_id %>/posts/<%= post.post_id %>"><%= post.title %></a></li>
  <% }) %>
</ul>
<%- include('partials/footer') %>
