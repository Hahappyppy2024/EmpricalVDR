<%- include('partials/header') %>
<h1>Posts: <%= course.title %></h1>
<p><a href="/courses/<%= course.course_id %>/posts/new">Create Post</a></p>
<ul>
  <% posts.forEach(function(post) { %>
    <li><a href="/courses/<%= course.course_id %>/posts/<%= post.post_id %>"><%= post.title %></a></li>
  <% }) %>
</ul>
<%- include('partials/footer') %>
