<%- include('partials/header') %>
<h1>Edit Assignment</h1>
<% if (error) { %><p style="color:red;"><%= error %></p><% } %>
<form method="post" action="/courses/<%= course.course_id %>/assignments/<%= assignment.assignment_id %>">
  <div><label>Title</label><input type="text" name="title" value="<%= assignment.title %>" required></div>
  <div><label>Description</label><textarea name="description"><%= assignment.description %></textarea></div>
  <div><label>Due At</label><input type="text" name="due_at" value="<%= assignment.due_at || '' %>"></div>
  <button type="submit">Save</button>
</form>
<%- include('partials/footer') %>
