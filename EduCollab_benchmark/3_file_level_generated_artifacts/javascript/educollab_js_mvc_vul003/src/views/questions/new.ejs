<%- include('../partials/header') %>
<h2>New Question</h2>
<p><a href="/courses/<%= course_id %>/questions">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/questions">
  <label>qtype</label>
  <input name="qtype" placeholder="mcq|text" />
  <label>prompt</label>
  <textarea name="prompt" rows="5"></textarea>
  <label>options_json (optional)</label>
  <textarea name="options_json" rows="3" placeholder='["A","B","C"]'></textarea>
  <label>answer_json (optional)</label>
  <textarea name="answer_json" rows="3" placeholder='{"correct":"A"}'></textarea>
  <button type="submit">Create</button>
</form>
<%- include('../partials/footer') %>
