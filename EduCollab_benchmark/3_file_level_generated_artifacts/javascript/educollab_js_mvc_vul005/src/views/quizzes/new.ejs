<%- include('../partials/header') %>
<h2>New Quiz</h2>
<p><a href="/courses/<%= course_id %>/quizzes">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/quizzes">
  <label>Title</label>
  <input name="title" />
  <label>Description</label>
  <textarea name="description" rows="5"></textarea>
  <label>Open at (ISO)</label>
  <input name="open_at" placeholder="2026-02-21T00:00:00Z" />
  <label>Due at (ISO)</label>
  <input name="due_at" placeholder="2026-02-28T00:00:00Z" />
  <button type="submit">Create</button>
</form>
<%- include('../partials/footer') %>
