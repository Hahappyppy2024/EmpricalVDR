<%- include('../partials/header') %>
<h2>Quiz Attempt #<%= attempt.attempt_id %></h2>
<p><a href="/courses/<%= course_id %>/quizzes/<%= quiz_id %>">Back to quiz</a></p>
<div class="card">
  <p class="muted">Started: <%= attempt.started_at %> • Submitted: <%= attempt.submitted_at || 'not yet' %></p>
  <% questions.forEach(q => { %>
    <div style="border-bottom:1px solid #eee;padding:10px 0">
      <p><b>Q<%= q.question_id %></b> (<%= q.qtype %>) — <%= q.points %> pts</p>
      <p><%= q.prompt %></p>
      <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz_id %>/attempts/<%= attempt.attempt_id %>/answers">
        <input type="hidden" name="question_id" value="<%= q.question_id %>" />
        <label>answer_json (string)</label>
        <textarea name="answer_json" rows="2"><%= q.existing_answer %></textarea>
        <button type="submit">Save answer</button>
      </form>
    </div>
  <% }) %>

  <form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz_id %>/attempts/<%= attempt.attempt_id %>/submit" onsubmit="return confirm('Submit attempt?')">
    <button type="submit">Submit attempt</button>
  </form>
</div>
<%- include('../partials/footer') %>
