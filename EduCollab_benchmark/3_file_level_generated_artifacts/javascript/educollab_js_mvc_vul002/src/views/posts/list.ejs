<%- include('../partials/header') %>
<h2>Posts</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/posts/new">New post</a> | <a href="/courses/<%= course_id %>/search?keyword=">Search</a></p>
<% posts.forEach(p => { %>
  <div class="card">
    <h3><a href="/courses/<%= course_id %>/posts/<%= p.post_id %>"><%= p.title %></a></h3>
    <p class="muted">by <%= p.author_username %> • <%= p.created_at %></p>
    <p><%= p.body.slice(0,200) %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
