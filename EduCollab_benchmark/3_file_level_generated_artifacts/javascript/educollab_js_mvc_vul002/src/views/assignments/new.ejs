<%- include('../partials/header') %>
<h2>New Assignment</h2>
<p><a href="/courses/<%= course_id %>/assignments">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/assignments">
  <label>Title</label>
  <input name="title" />
  <label>Description</label>
  <textarea name="description" rows="6"></textarea>
  <label>Due at (ISO string)</label>
  <input name="due_at" placeholder="2026-02-21T23:59:00Z" />
  <button type="submit">Create</button>
</form>
<%- include('../partials/footer') %>
