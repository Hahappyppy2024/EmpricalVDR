<%- include('../partials/header') %>
<h2>Uploads</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/uploads/new">Upload file (staff)</a></p>
<% uploads.forEach(u => { %>
  <div class="card">
    <p><b>#<%= u.upload_id %></b> <%= u.original_name %></p>
    <p class="muted">by <%= u.uploaded_by_username %> • <%= u.created_at %></p>
    <p><a href="/courses/<%= course_id %>/uploads/<%= u.upload_id %>/download">Download</a></p>
    <form method="post" action="/courses/<%= course_id %>/uploads/<%= u.upload_id %>/delete" onsubmit="return confirm('Delete upload?')">
      <button type="submit">Delete</button>
    </form>
  </div>
<% }) %>
<%- include('../partials/footer') %>
