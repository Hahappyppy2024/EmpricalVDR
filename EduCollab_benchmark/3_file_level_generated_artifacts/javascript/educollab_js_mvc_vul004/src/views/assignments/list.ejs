<%- include('../partials/header') %>
<h2>Assignments</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/assignments/new">New assignment</a> | <a href="/courses/<%= course_id %>/uploads">Uploads</a></p>
<% assignments.forEach(a => { %>
  <div class="card">
    <h3><a href="/courses/<%= course_id %>/assignments/<%= a.assignment_id %>"><%= a.title %></a></h3>
    <p class="muted">Due: <%= a.due_at %> • by <%= a.created_by_username %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
