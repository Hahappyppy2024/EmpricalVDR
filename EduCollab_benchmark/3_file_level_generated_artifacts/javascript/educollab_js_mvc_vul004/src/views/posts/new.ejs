<%- include('../partials/header') %>
<h2>New Post</h2>
<p><a href="/courses/<%= course_id %>/posts">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/posts">
  <label>Title</label>
  <input name="title" />
  <label>Body</label>
  <textarea name="body" rows="8"></textarea>
  <button type="submit">Create</button>
</form>
<%- include('../partials/footer') %>
