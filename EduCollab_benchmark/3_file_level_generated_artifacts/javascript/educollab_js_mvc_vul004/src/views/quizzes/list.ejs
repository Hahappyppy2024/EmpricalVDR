<%- include('../partials/header') %>
<h2>Quizzes</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/quizzes/new">New quiz (staff)</a></p>
<% quizzes.forEach(q => { %>
  <div class="card">
    <h3><a href="/courses/<%= course_id %>/quizzes/<%= q.quiz_id %>"><%= q.title %></a></h3>
    <p class="muted">Open: <%= q.open_at %> • Due: <%= q.due_at %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
