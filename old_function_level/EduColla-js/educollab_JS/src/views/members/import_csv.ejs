<%- include('../partials/header') %>
<h2>Import Members CSV</h2>
<p>Course <%= course_id %></p>
<% if (typeof error !== 'undefined') { %><p style="color:red"><%= error %></p><% } %>
<p>Expected headers: <code>username,display_name,role_in_course</code></p>
<form method="post" action="/courses/<%= course_id %>/members/import" enctype="multipart/form-data">
  <input type="file" name="csv" accept=".csv,text/csv" />
  <button type="submit">Import</button>
</form>
<p><a href="/courses/<%= course_id %>/members">Back</a></p>
<%- include('../partials/footer') %>
