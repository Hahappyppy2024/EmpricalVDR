<%- include('../partials/header') %>
<h2>Import Assignment Grades CSV</h2>
<p>Course <%= course_id %>, Assignment <%= assignment_id %></p>
<% if (typeof error !== 'undefined') { %><p style="color:red"><%= error %></p><% } %>
<p>Expected headers: <code>submission_id,score,feedback</code></p>
<form method="post" action="/courses/<%= course_id %>/assignments/<%= assignment_id %>/grades/import" enctype="multipart/form-data">
  <input type="file" name="csv" accept=".csv,text/csv" />
  <button type="submit">Import grades</button>
</form>
<p><a href="/courses/<%= course_id %>/assignments/<%= assignment_id %>/submissions">Back</a></p>
<%- include('../partials/footer') %>
