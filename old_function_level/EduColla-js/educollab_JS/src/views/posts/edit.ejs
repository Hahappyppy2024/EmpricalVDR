<%- include('../partials/header') %>
<h2>Edit Post</h2>
<p><a href="/courses/<%= course_id %>/posts/<%= post.post_id %>">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/posts/<%= post.post_id %>">
  <label>Title</label>
  <input name="title" value="<%= post.title %>" />
  <label>Body</label>
  <textarea name="body" rows="8"><%= post.body %></textarea>
  <button type="submit">Save</button>
</form>
<%- include('../partials/footer') %>
