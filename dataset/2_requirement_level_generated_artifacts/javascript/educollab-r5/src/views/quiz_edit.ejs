<%- include('partials/header') %>
<h1>Edit Quiz</h1>
<% if (error) { %><p style="color:red;"><%= error %></p><% } %>
<form method="post" action="/courses/<%= course.course_id %>/quizzes/<%= quiz.quiz_id %>">
  <div><label>Title</label><input type="text" name="title" value="<%= quiz.title %>" required></div>
  <div><label>Description</label><textarea name="description"><%= quiz.description %></textarea></div>
  <div><label>Open At</label><input type="text" name="open_at" value="<%= quiz.open_at || '' %>"></div>
  <div><label>Due At</label><input type="text" name="due_at" value="<%= quiz.due_at || '' %>"></div>
  <button type="submit">Save</button>
</form>
<%- include('partials/footer') %>
