<%- include('partials/header') %>

<h1><%= course.title %></h1>

<p><strong>Course ID:</strong> <%= course.course_id %></p>
<p><strong>Description:</strong> <%= course.description %></p>
<p><strong>Created by:</strong> <%= course.creator_display_name %> (@<%= course.creator_username %>)</p>
<p><strong>Created at:</strong> <%= course.created_at %></p>

<p>
  <a href="/courses/<%= course.course_id %>/edit">Edit</a>
  |
  <a href="/courses/<%= course.course_id %>/members">Members</a>
  |
  <a href="/courses/<%= course.course_id %>/posts">Posts</a>
  |
  <a href="/courses/<%= course.course_id %>/search">Search Posts</a>
  |
  <a href="/courses/<%= course.course_id %>/search/comments">Search Comments</a>
</p>

<form method="post" action="/courses/<%= course.course_id %>/delete">
  <button type="submit">Delete</button>
</form>

<%- include('partials/footer') %>
