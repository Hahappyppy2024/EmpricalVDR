<%- include('../partials/header') %>

<h2>Audit Log</h2>
<p>This page shows recent audit records (A09 surface). Some critical security events may be missing by design.</p>

<table border="1" cellpadding="6" cellspacing="0" style="width:100%; border-collapse: collapse;">
  <thead>
    <tr>
      <th>ID</th>
      <th>Time</th>
      <th>Actor</th>
      <th>Action</th>
      <th>Target</th>
      <th>Meta</th>
    </tr>
  </thead>
  <tbody>
    <% if (!rows || rows.length === 0) { %>
      <tr><td colspan="6"><em>No audit records.</em></td></tr>
    <% } else { %>
      <% rows.forEach(r => { %>
        <tr>
          <td><%= r.audit_id %></td>
          <td><%= r.created_at %></td>
          <td><%= (r.actor_username || '') %></td>
          <td><%= r.action %></td>
          <td><%= (r.target_type || '') %><%= (r.target_id ? ('#' + r.target_id) : '') %></td>
          <td><%= r.meta_json || '' %></td>
        </tr>
      <% }) %>
    <% } %>
  </tbody>
</table>

<%- include('../partials/footer') %>
