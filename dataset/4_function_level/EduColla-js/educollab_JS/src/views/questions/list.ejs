<%- include('../partials/header') %>
<h2>Question Bank</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/questions/new">New question</a></p>
<% questions.forEach(q => { %>
  <div class="card">
    <h3><a href="/courses/<%= course_id %>/questions/<%= q.question_id %>">Q#<%= q.question_id %></a> (<%= q.qtype %>)</h3>
    <p><%= q.prompt %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
