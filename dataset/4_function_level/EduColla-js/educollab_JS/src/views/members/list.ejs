<%- include('../partials/header') %>
<h2>Course Members</h2>
<p><a href="/courses/<%= course_id %>">Back to course</a></p>
<p><a href="/courses/<%= course_id %>/members/new">Add member</a></p>
<% if (can_generate_invite) { %>
  <hr/>
  <h3>Invite link</h3>
  <form method="post" action="/courses/<%= course_id %>/invites">
    <label>Role:
      <select name="role_in_course">
        <option value="student" selected>student</option>
        <option value="assistant">assistant</option>
        <option value="senior-assistant">senior-assistant</option>
      </select>
    </label>
    <label>TTL (minutes):
      <input type="number" name="ttl_minutes" value="1440" min="5" />
    </label>
    <button type="submit">Generate invite link</button>
  </form>

  <% if (invite_link) { %>
    <p><b>Generated link:</b> <a href="<%= invite_link %>"><%= invite_link %></a></p>
    <p style="font-size: 0.9em; color: #666;">Share this link with a user who should join the course.</p>
  <% } %>
<% } %>
<div class="card">
  <table width="100%" border="1" cellspacing="0" cellpadding="6">
    <tr><th>membership_id</th><th>user</th><th>role</th><th>actions</th></tr>
    <% members.forEach(m => { %>
      <tr>
        <td><%= m.membership_id %></td>
        <td><%= m.username %> (<%= m.display_name %>)</td>
        <td>
          <form method="post" action="/courses/<%= course_id %>/members/<%= m.membership_id %>">
            <select name="role_in_course">
              <% roles.forEach(r => { %>
                <option value="<%= r %>" <%= m.role_in_course===r?'selected':'' %>><%= r %></option>
              <% }) %>
            </select>
            <button type="submit">Update</button>
          </form>
        </td>
        <td>
          <form method="post" action="/courses/<%= course_id %>/members/<%= m.membership_id %>/delete" onsubmit="return confirm('Remove?')">
            <button type="submit">Remove</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>
<%- include('../partials/footer') %>
