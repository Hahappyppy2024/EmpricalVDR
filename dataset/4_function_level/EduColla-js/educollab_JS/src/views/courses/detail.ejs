<%- include('../partials/header') %>
<h2>Course: <%= course.title %></h2>
<p><a href="/courses/<%= course.course_id %>/materials/files">Materials</a></p>
<div class="card">
  <p><%= course.description %></p>
  <div class="row">
    <div>
      <h4>People</h4>
      <a href="/courses/<%= course.course_id %>/members">Members</a>
    </div>
    <div>
      <h4>Content</h4>
      <a href="/courses/<%= course.course_id %>/posts">Posts</a><br/>
      <a href="/courses/<%= course.course_id %>/search?keyword=">Search posts</a>
    </div>
    <div>
      <h4>Work</h4>
      <a href="/courses/<%= course.course_id %>/assignments">Assignments</a><br/>
      <a href="/courses/<%= course.course_id %>/uploads">Uploads</a>
    </div>
    <div>
      <h4>Quizzes</h4>
      <a href="/courses/<%= course.course_id %>/quizzes">Quizzes</a><br/>
      <a href="/courses/<%= course.course_id %>/questions">Question bank</a>
    </div>
  </div>
  <p style="margin-top:10px">
    <a href="/courses/<%= course.course_id %>/edit">Edit</a>
  </p>
  <form method="post" action="/courses/<%= course.course_id %>/delete" onsubmit="return confirm('Delete course?')">
    <button type="submit">Delete course</button>
  </form>
</div>
<%- include('../partials/footer') %>
