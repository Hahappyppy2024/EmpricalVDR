<%- include('../partials/header') %>
<h2>Edit Quiz</h2>
<p><a href="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/quizzes/<%= quiz.quiz_id %>">
  <label>Title</label>
  <input name="title" value="<%= quiz.title %>" />
  <label>Description</label>
  <textarea name="description" rows="5"><%= quiz.description %></textarea>
  <label>Open at</label>
  <input name="open_at" value="<%= quiz.open_at %>" />
  <label>Due at</label>
  <input name="due_at" value="<%= quiz.due_at %>" />
  <button type="submit">Save</button>
</form>
<%- include('../partials/footer') %>
