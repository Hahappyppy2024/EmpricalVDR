<%- include('../partials/header') %>
<h2>Search Comments</h2>
<p><a href="/courses/<%= course_id %>/posts">Back to posts</a></p>
<form method="get" action="/courses/<%= course_id %>/search/comments">
  <input name="keyword" value="<%= keyword %>" placeholder="keyword" />
  <button type="submit">Search</button>
</form>
<% comments.forEach(c => { %>
  <div class="card">
    <p class="muted"><%= c.author_username %> • post_id=<%= c.post_id %></p>
    <p><%= c.body %></p>
  </div>
<% }) %>
<%- include('../partials/footer') %>
