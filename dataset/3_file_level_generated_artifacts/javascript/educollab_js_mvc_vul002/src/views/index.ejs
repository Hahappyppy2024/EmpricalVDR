<%- include('partials/header') %>
<h1>EduCollab JS MVC v0</h1>
<div class="card">
  <p>This is a minimal MVC Node.js + Express + SQLite app.</p>
  <ul>
    <li>Default admin: <b>admin</b> / <b>admin123</b></li>
    <li>Both HTML and JSON API under <code>/api</code> use the same session.</li>
  </ul>
  <% if (!me) { %>
    <p><a href="/login">Login</a> or <a href="/register">Register</a></p>
  <% } else { %>
    <p>Welcome, <b><%= me.display_name %></b>. Go to <a href="/courses">Courses</a>.</p>
  <% } %>
</div>
<%- include('partials/footer') %>
