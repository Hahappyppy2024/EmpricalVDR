<%- include('../partials/header') %>
<h2>Edit Question</h2>
<p><a href="/courses/<%= course_id %>/questions/<%= question.question_id %>">Back</a></p>
<form method="post" action="/courses/<%= course_id %>/questions/<%= question.question_id %>">
  <label>qtype</label>
  <input name="qtype" value="<%= question.qtype %>" />
  <label>prompt</label>
  <textarea name="prompt" rows="5"><%= question.prompt %></textarea>
  <label>options_json</label>
  <textarea name="options_json" rows="3"><%= question.options_json || '' %></textarea>
  <label>answer_json</label>
  <textarea name="answer_json" rows="3"><%= question.answer_json || '' %></textarea>
  <button type="submit">Save</button>
</form>
<%- include('../partials/footer') %>
